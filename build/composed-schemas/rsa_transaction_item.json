      },
      "cancellations": {
        "type": "array",
        "items": {
          "type": "object",
          "$ref": "#/components/schemas/v1alpha1RsaCancellationTransaction"
        },
        "description": "All cancellation and termination transactions for the RSA, in chronological order."
      }
    },
    "description": "An RSA with its full transaction history. Groups all lifecycle events (issuance, cancellation) for a single RSA."
  },
