{
  "name": "v1alpha1RsaTransactionItem",
  "sanitized_name": "rsa_transaction_item",
  "schema_type": "type",
  "schema_def": {
    "type": "object",
    "example": {
      "securityId": "4101",
      "stakeholderId": "4923",
      "securityLabel": "RSA-3",
      "issuance": {
        "issueDatetime": {
          "value": "2024-01-15T00:00:00Z"
        },
        "quantity": {
          "value": "5000"
        },
        "acquisitionCost": {
          "currencyCode": {
            "value": "USD"
          },
          "amount": {
            "value": "0.001"
          }
        },
        "equityPlanId": "42"
      }
    },
    "properties": {
      "securityId": {
        "type": "string",
        "description": "The identifier of the RSA.",
        "maxLength": 50
      },
      "stakeholderId": {
        "type": "string",
        "description": "The identifier of the current holder of the RSA.",
        "maxLength": 50
      },
      "securityLabel": {
        "type": "string",
        "description": "The human-readable label for the RSA (e.g. \"RSA-3\").",
        "maxLength": 50
      },
      "issuance": {
